# Rust build artifacts
/target
**/*.rs.bk

# Python
__pycache__/
*.pyc

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Agentic-tool local state (Claude Code, Cursor, opencode, etc.)
# These hold per-machine session data, not project state.
.claude/
.cursor/
.opencode/
.aider*

# Local environment files (never commit secrets)
.env
.env.*
.envrc

# Log files (audit logs are typically streamed elsewhere; if a user
# captures one in-tree it's almost always personal-machine output)
*.log
audit.jsonl
*.audit.jsonl

# Coverage / profiling
*.profraw
*.profdata
